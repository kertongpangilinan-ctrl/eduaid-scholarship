{
  "buildCommand": "composer install --ignore-platform-reqs --no-dev && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "public",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.php" }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://eduaid-scholarship.vercel.app",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr"
  }
}
